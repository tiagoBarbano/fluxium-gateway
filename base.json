[
  {
    "_id": "69a78fa296247404432e6bcd",
    "tenant": "teste",
    "prefix": "/ws/{cep}/json/",
    "target_base": "https://viacep.com.br",
    "strip_prefix": true,
    "plugins": [
      {
        "type": "oauth22",
        "order": 1,
        "config": {
          "issuer": "https://keycloak.meudominio.com/realms/myrealm",
          "audience": "gateway-api",
          "required_scopes": [
            "pricing.read"
          ]
        }
      },
      {
        "type": "rate_limit",
        "order": 2,
        "config": {
          "limit": 5,
          "window_seconds": 60,
          "by_consumer": true,
          "consumer_limits": {
            "consumer-enterprise-1": {
              "limit": 100,
              "window_seconds": 60
            }
          },
          "consumer_tag_limits": {
            "vip": {
              "limit": 200,
              "window_seconds": 60
            }
          }
        }
      },
      {
        "type": "logging",
        "order": 3,
        "config": {
          "log_request": true,
          "log_response": true,
          "mask_sensitive_enabled": true,
          "sensitive_fields": [
            "password",
            "token",
            "cpf",
            "email"
          ],
          "mask_value": "***",
          "max_body_chars": 4000
        }
      },
      {
        "type": "cors",
        "order": 1,
        "config": {
          "allowed_origins": [
            "https://app.seudominio.com"
          ],
          "allowed_methods": [
            "GET",
            "POST",
            "OPTIONS"
          ],
          "allowed_headers": [
            "authorization",
            "content-type",
            "x-api-key"
          ],
          "allow_credentials": true,
          "max_age": 600,
          "block_disallowed_origin": true
        }
      },
      {
        "type": "api_key",
        "order": 2,
        "config": {
          "header_name": "x-api-key",
          "query_param": "api_key",
          "keys": [
            "key-prod-1",
            "key-prod-2"
          ],
          "resolve_consumer": true,
          "enforce_consumer_resolution": true
        }
      },
      {
        "type": "consumer_acl",
        "order": 3,
        "config": {
          "allow_anonymous": false,
          "allow_tags": [
            "vip",
            "partner"
          ],
          "required_actor_types": [
            "application",
            "service"
          ]
        }
      },
      {
        "type": "ip_restriction",
        "order": 4,
        "config": {
          "source": "x-forwarded-for",
          "allowlist": [
            "10.0.0.0/8",
            "192.168.1.0/24"
          ],
          "denylist": [
            "10.0.13.37"
          ]
        }
      },
      {
        "type": "request_size",
        "order": 5,
        "config": {
          "max_bytes": 1048576
        }
      },
      {
        "type": "correlation_id",
        "order": 6,
        "config": {
          "incoming_header": "x-request-id",
          "upstream_header": "x-request-id",
          "response_header": "x-request-id"
        }
      },
      {
        "type": "retry",
        "order": 0,
        "config": {
          "attempts": 3,
          "retry_on": [
            502,
            503,
            504
          ],
          "backoff_ms": 50
        }
      },
      {
        "type": "cache",
        "order": 4,
        "config": {
          "ttl_seconds": 60
        }
      },
      {
        "type": "circuit_breaker",
        "order": 0,
        "config": {
          "failure_threshold": 2,
          "recovery_timeout_seconds": 10
        }
      },
      {
        "type": "forward_auth",
        "order": 0,
        "config": {
          "mode": "oauth2_client_credentials",
          "token_url": "https://idp.exemplo.com/realms/myrealm/protocol/openid-connect/token",
          "client_id": "gateway-upstream-client",
          "client_secret": "<secret>",
          "scope": "pricing.read",
          "target_header": "authorization"
        }
      }
    ]
  },
  {
    "prefix": "/orders",
    "target_base": "http://orders-service",
    "strip_prefix": false,
    "plugins": [
      {
        "type": "validation",
        "order": 1,
        "config": {
          "allowed_methods": [
            "POST"
          ],
          "required_fields": [
            "order_id",
            "customer_id"
          ],
          "header_rules": [
            {
              "name": "x-source",
              "required": true,
              "equals": "portal"
            }
          ],
          "query_rules": [
            {
              "name": "version",
              "required": true,
              "equals": "v1"
            }
          ]
        }
      },
      {
        "type": "logging",
        "order": 1,
        "config": {
          "log_request": true,
          "log_response": true,
          "mask_sensitive_enabled": true,
          "sensitive_fields": [
            "password",
            "token",
            "cpf",
            "email"
          ],
          "mask_value": "***",
          "max_body_chars": 4000
        }
      },
      {
        "type": "transformation",
        "order": 2,
        "config": {
          "set_headers": {
            "x-origin": "gateway"
          },
          "remove_headers": [
            "x-debug"
          ],
          "json_rename": {
            "customer_id": "client_id"
          },
          "json_defaults": {
            "source": "gateway",
            "channel": "api"
          },
          "json_remove": [
            "internal_notes"
          ]
        }
      },
      {
        "type": "event_bridge",
        "order": 3,
        "config": {
          "mode": "stream",
          "stream": "orders.events",
          "include_headers": false,
          "event": {
            "domain": "orders",
            "event_type": "order.received"
          },
          "forward_after_publish": true
        }
      },
      {
        "type": "request_size",
        "order": 4,
        "config": {
          "max_bytes": 262144
        }
      },
      {
        "type": "correlation_id",
        "order": 5,
        "config": {
          "incoming_header": "x-correlation-id",
          "upstream_header": "x-correlation-id",
          "response_header": "x-correlation-id"
        }
      }
    ]
  }
]